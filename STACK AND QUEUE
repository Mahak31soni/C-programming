#include <stdio.h>
#define MAX 5
int stack[MAX];
int top = -1;

void push(int x){
    if(top == MAX-1) 
    {printf("stack overflow");
    return; }
    top++;
    stack[top] = x;
}

void pop()
{
    if(top == -1)
    {
        printf("stack underflow");
        return;
    }
    top--;
}
int peek()
{
    if(top == -1)
    {
        printf("stack underflow");
        return -1;
    }
    return stack[top];
}
void display()
{
    if(top == -1)
    {
        printf("stack underflow");
        return;
    }
    int i = top;
    while(i != -1)
    {
        printf("%d\n", stack[i]);
        i--;
    }
}
