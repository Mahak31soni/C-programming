///////////////////////////////////////////////stack using LL in C
#include<stdlib.h>
#include <stdio.h>
struct Node
{
    int data;
    struct Node* next;
};

struct Node* top = NULL;

void push(int x)
{
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp->data = x;
    temp->next= top;
    top = temp;
}
void pop()
{
    if(top == NULL)
    {printf("stack underflow");
        return;
    }
    struct Node* temp  = top;
    top = top->next;
    free(temp);
}

void peek()
{
    if(top == NULL)
    {
        printf("Stack Underflow\n");
        return;
    }
    printf("Peek %d\n",top->data);
}

void display()
{
    if(top == NULL)
    {printf("stack underflow");
        return;
    }
    struct Node* temp = top;
    while(temp != NULL)
    {
        printf("%d\n",temp->data);
        temp= temp->next;
    }
}
int main()
{
    push(5);
    peek();
    display();
}
