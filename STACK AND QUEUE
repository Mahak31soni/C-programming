//////////////////////////////////////////////// Stack using Array in C++
#include <iostream>
#include <bits/stdc++.h>
using namespace std;

class solution
{
private:
    int top;
    int stack[10];
    int poppedvalue ;
    const int SIZE = 10;
public:
    solution()
    {
        top = -1;//empty stack
        poppedvalue = 0;
    }
    
    void push(int x)
    {
        if(top == SIZE-1) {cout <<"overflow\n"; return; }
        stack[++top] = x;
    }
    void pop()
    {
        if (top == -1) {cout << "underflow\n"; return ;}
        poppedvalue = stack[top--];
        cout<<poppedvalue<<" popped " << " "<<endl;
    }
    void display()
    {
        for(int i = 0; i <= top; i++ ) 
        {cout << stack[i] << " ";
        cout<<endl;}
    }

};

int main() {
    solution s;
    s.push(10);
    s.push(20);
    s.push(30);
    s.display();
    s.pop();
    s.push(40);
    s.display();
    return 0;
}



///////////////////////////////////////////////////// QUEUE USING ARRAY in C++
#include <iostream>
#include <bits/stdc++.h>
using namespace std;

class solution
{
private:
    int front;
    int rear;
    static const int SIZE = 10;
    int queue[SIZE];
public:
    solution()
    {
        front = -1;//empty stack
        rear = -1;
    }
    
    void enqueue(int x)
    {
        if(rear == SIZE-1) {cout <<"overflow\n"; return; }
        if(front == -1) front = 0;
        queue[++rear] = x;
    }
    void dequeue()
    {
        if (front == -1 || front> rear) {cout << "underflow\n"; return ;}

        cout<<queue[front] << "popped\n";
        front++;
        if (front > rear)
        {
            front = -1;
            rear = -1;
        }
    }
    void display()
    {
        if (front == -1)
        {
            cout << "Queue is Empty\n";
            return;
        }
        for(int i = front; i <= rear; i++ ) 
        {cout << queue[i] << " ";
        cout<<endl;}
    }
};
int main() {
    solution q;
    q.enqueue(10);
    q.enqueue(20);
    q.enqueue(30);
    q.display();
    q.dequeue();
    q.dequeue();
    q.dequeue();
    q.dequeue();
    // q.enqueue(40);
    q.display();
    return 0;
}

/////////////////////////////////////////////////////////////stack using linked list (Dynamic Stack) in c++

#include <iostream>
#include <bits/stdc++.h>
using namespace std;

class Node
{
public:
  int data;
  Node *next;
};
class Stack
{
private:
 Node* top;
public:
    Stack()
    {
        top = nullptr;
    };
    void push(int x)
    {
        Node* temp = new Node();
        temp->data = x;
        temp->next = top;
        top = temp;
    };
    void pop()
    {
        if(top==nullptr) return;
        Node * temp = top;
        top = temp->next;
        delete temp;
        
    };
    void display()
    {
        Node* temp = top;
        while(temp !=nullptr)
        {
        cout<< temp->data<< " ";
        temp = temp->next;
        }
    }
    
};

int main() {
    Stack s;
    s.push(20);
    s.push(30);
    s.pop();
    s.display();
    return 0;
}


