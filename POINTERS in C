Create a 3 × 4 dynamic 2D array--------------*****************************************************************************************
#include <stdio.h>
#include <stdlib.h>

int main()
{
    int rows = 3;
    int columns = 4;
    
    int ** a;//a will point to row pointers
    
    a = (int**) malloc(rows*sizeof(int*));//create space for 3 row pointers
    
    for(int i=0;i<rows; i++)
    {
        a[i] = malloc(columns*sizeof(int));
    }
    
    int value = 0;
    for(int i = 0; i<rows; i++)
    {
        for(int j= 0; j<columns; j++)
        {
            a[i][j] = value++;
        }
    }
    // Print the array
    for(int i = 0; i < rows; i++)
    {
        for(int j = 0; j < columns; j++)
        {
            printf("%d ", a[i][j]);
        }
        printf("\n");
    }

    // Free each row
    for(int i = 0; i < rows; i++)
    {
        free(a[i]);
    }

    // Free the row-pointer array
    free(a);

    return 0;
    
}

