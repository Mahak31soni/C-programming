///////////////////////////////////using substr O(n)
Problem 1: Reverse the Order of Words
Input: "virat kholi is the best"
o/p: "best the is kholi virat"


#include<iostream>
using namespace std;

int main()
{
    string str = "virat kholi is the best";
    int end = str.length();
    
    for(int i = str.length()-1; i>= 0; i--)
    {
        if(str[i] == ' ')
        {
            cout << str.substr(i+1, end-i-1);
            cout<<' ';
            end = i;
        }
    }

    cout<< str.substr(0,end);
}

