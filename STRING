///////////////////////////////problem 2: Reverse the character of each word
i/p: "Mehak Soni"
o/p: "inoS kaheM"



#include<iostream>
using namespace std;

int main()
{
    string str = "Mahak Soni";
    int end = str.length();
    for(int i=0; i<end; i++)
    {
        if(str[i] == ' ' || i == str.length()-1)
        {
            for(int j = end-1; j>=i+1; j--)
            {cout<< str[j];}
            cout<< " ";
            end = i;
        }
    }
    for(int i=end-1; i>=0; i--)
    {cout<<str[i];}
    
}
